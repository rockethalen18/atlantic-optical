# ============================================
# Configuración de Deploy - Banahosting
# ============================================
# Copia este archivo a .env.deploy y llena tus datos

# FTP Configuration (de Banahosting cPanel)
FTP_HOST=ftp.tudominio.com
FTP_USER=usuario@tudominio.com
FTP_PASS=tu_contraseña_ftp
FTP_DIR=/public_html

# API URL (tu dominio)
NEXT_PUBLIC_API_URL=https://tudominio.com/backend/api
